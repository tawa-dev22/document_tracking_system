SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Initial Admin Seeding (Used only on first startup if no admin exists)
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
